# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — ARIRAS API Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values in .env
# 3. Never commit .env to git  (it's in .gitignore)
#
# On Render / Railway: set these in the platform's environment variables UI
# instead of using a .env file.
# ═══════════════════════════════════════════════════════════════════════════════


# ── App identity ──────────────────────────────────────────────────────────────
APP_NAME=ARIRAS API
APP_VERSION=2.0.0
ENVIRONMENT=development        # change to "production" when deploying


# ── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random secret in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── Demo credentials ──────────────────────────────────────────────────────────
# In production: replace with a real user database + hashed passwords.
DEMO_USERNAME=ariras_user
DEMO_PASSWORD=ariras_pass


# ── LLM API keys ──────────────────────────────────────────────────────────────
# Get your Groq key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: OpenAI fallback (leave blank if not using)
OPENAI_API_KEY=


# ── Storage paths ─────────────────────────────────────────────────────────────
# These are relative to the working directory (project root).
# In Docker these are inside the container — mount volumes to persist data.
CHROMA_PERSIST_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads


# ── Rate limiting ─────────────────────────────────────────────────────────────
# Format: "N/period" where period = second | minute | hour | day
RATE_LIMIT_QUERY=5/minute       # LLM-backed endpoints (protect API spend)
RATE_LIMIT_UPLOAD=10/minute     # file upload + embedding
RATE_LIMIT_DEFAULT=30/minute    # all other endpoints


# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=10000
